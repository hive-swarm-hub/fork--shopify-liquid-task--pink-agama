lterMarkupRegex\n332\t        filters = Regexp.last_match(1).scan(FilterParser)\n333\t        filters.each do |f|\n334\t          next unless f =~ /\\w+/\n335\t          filtername = Regexp.last_match(0)\n336\t          filterargs = f.scan(FilterArgsRegex).flatten\n337\t          @filters = [] if @filters.frozen?\n338\t          @filters << lax_parse_filter_expressions(filtername, filterargs)\n339\t        end\n340\t      end\n341\t    end\n342\t\n343\t    def strict_parse(markup)\n344\t      @filters = Const::EMPTY_ARRAY\n345\t      p = @parse_context.new_parser(markup)\n346\t\n347\t      return if p.look(:end_of_string)\n348\t\n349\t      @name = parse_context.safe_parse_expression(p)\n350\t      while p.consume?(:pipe)\n351\t        @filters = [] if @filters.frozen?\n352\t        filtername = p.consume(:id)\n353\t        filterargs = p.consume?(:colon) ? parse_filterargs(p) : Const::EMPTY_ARRAY\n354\t        @filters << lax_parse_filter_expressions(filtername, filterargs)\n355\t      end\n356\t      p.consume(:end_of_string)\n357\t    end\n358\t\n359\t    def strict2_parse(markup)\n360\t      @filters = Const::EMPTY_ARRAY\n361\t      p = @parse_context.new_parser(markup)\n362\t\n363\t      return if p.look(:end_of_string)\n364\t\n365\t      @name = parse_context.safe_parse_expression(p)\n366\t      while p.consume?(:pipe)\n367\t        @filters = [] if @filters.frozen?\n368\t        @filters << strict2_parse_filter_expressions(p)\n369\t      end\n370\t      p.consume(:end_of_string)\n371\t    end\n372\t\n373\t    def parse_filterargs(p)\n374\t      # first argument\n375\t      filterargs = [p.argument]\n376\t      # followed by comma separated others\n377\t      filterargs << p.argument while p.consume?(:comma)\n378\t      filterargs\n379\t    end\n380\t\n381\t    def render(context)\n382\t      obj = context.evaluate(@name)\n383\t\n384\t      @filters.each do |filter_name, filter_args, filter_kwargs|\n385\t        if filter_args.empty? && !filter_kwargs\n386\t  
0) || (b >= 48 && b <= 57) || b == 95 || b == 45\n205\t          filter_pos += 1\n206\t        end\n207\t        filtername = markup.byteslice(fname_start, filter_pos - fname_start)\n208\t\n209\t        # Skip whitespace\n210\t        filter_pos += 1 while filter_pos < len && markup.getbyte(filter_pos) == 32\n211\t\n212\t        # Has arguments — try fast scanning for positional args\n213\t        if filter_pos < len && markup.getbyte(filter_pos) == 58 # ':'\n214\t          filter_pos += 1 # skip ':'\n215\t          filter_pos += 1 while filter_pos < len && markup.getbyte(filter_pos) == 32\n216\t\n217\t          filter_args = []\n218\t          fall_to_lexer = false\n219\t\n220\t          loop do\n221\t            arg_start = filter_pos\n222\t            b = filter_pos < len ? markup.getbyte(filter_pos) : nil\n223\t\n224\t            if b == 39 || b == 34 # quoted string\n225\t              quote = b\n226\t              filter_pos += 1\n227\t              filter_pos += 1 while filter_pos < len && markup.getbyte(filter_pos) != quote\n228\t              filter_pos += 1 if filter_pos < len # skip closing quote\n229\t              filter_args << markup.byteslice(arg_start + 1, filter_pos - arg_start - 2)\n230\t            elsif b && ((b >= 48 && b <= 57) || (b == 45 && filter_pos + 1 < len && markup.getbyte(filter_pos + 1) >= 48 && markup.getbyte(filter_pos + 1) <= 57))\n231\t              # Number\n232\t              filter_pos += 1 if b == 45\n233\t              filter_pos += 1 while filter_pos < len && markup.getbyte(filter_pos) >= 48 && markup.getbyte(filter_pos) <= 57\n234\t              if filter_pos < len && markup.getbyte(filter_pos) == 46 # float\n235\t                filter_pos += 1\n236\t                filter_pos += 1 while filter_pos < len && markup.getbyte(filter_pos) >= 48 && markup.getbyte(filter_pos) <= 57\n237\t              end\n238\t              num_str = markup.byteslice(arg_start, filter_pos - arg_start)\n239\t              filter_args << (num_str.include?('.') ? num_str.to_f : num_str.to_i)\n240\t            elsif b && ((b >= 97 && b <= 122) || (b >= 65 && b <= 90) || b == 95)\n241\t              # Identifier\n242\t              id_start = filter_pos\n243\t              filter_pos += 1\n244\t              while filter_pos < len\n245\t                b2 = markup.getbyte(filter_pos)\n246\t                break unless (b2 >= 97 && b2 <= 122) || (b2 >= 65 && b2 <= 90) || (b2 >= 48 && b2 <= 57) || b2 == 95 || b2 == 45 || b2 == 46\n247\t                filter_pos += 1\n248\t              end\n249\t              filter_pos += 1 if filter_pos < len && markup.getbyte(filter_pos) == 63\n250\t\n251\t              # Check if keyword arg (id followed by ':')\n252\t              kw_check = filter_pos\n253\t              kw_check += 1 while kw_check < len && markup.getbyte(kw_check) == 32\n254\t              if kw_check < len && markup.getbyte(kw_check) == 58\n255\t                fall_to_lexer = true\n256\t                break\n257\t              end\n258\t\n259\t              id_markup = markup.byteslice(id_start, filter_pos - id_start)\n260\t              filter_args << Expression.parse(id_markup, parse_context.string_scanner, parse_context.expression_cache)\n261\t            else\n262\t              fall_to_lexer = true\n263\t              break\n264\t            end\n265\t\n266\t            # Skip whitespace after arg\n267\t            filter_pos += 1 while filter_pos < len && markup.getbyte(filter_pos) == 32\n268\t\n269\t            # Comma = more args; pipe/end = done\n270\t            if filter_pos < len && markup.getbyte(filter_pos) == 44\n271\t              filter_pos += 1\n272\t              filter_pos += 1 while filter_pos < len && markup.getbyte(filter_pos) == 32\n273\t            else\n274\t              break\n275\t            end\n276\t          end\n277\t\n278\t          if fall_to_lexer\n279\t            # Complex filter — fall to Lexer for this and remaining filters\n280\t            rest_start = fname
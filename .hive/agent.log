        sub_table.freeze\n44\t      end\n45\t      table[\"!\".ord] = [].tap do |sub_table|\n46\t        sub_table[\"=\".ord] = COMPARISION_NOT_EQUAL\n47\t        sub_table.freeze\n48\t      end\n49\t      table.freeze\n50\t    end\n51\t\n52\t    COMPARISON_JUMP_TABLE = [].tap do |table|\n53\t      table[\"<\".ord] = [].tap do |sub_table|\n54\t        sub_table[\"=\".ord] = COMPARISON_LESS_THAN_OR_EQUAL\n55\t        sub_table[\">\".ord] = COMPARISON_NOT_EQUAL_ALT\n56\t        sub_table.freeze\n57\t      end\n58\t      table[\">\".ord] = [].tap do |sub_table|\n59\t        sub_table[\"=\".ord] = COMPARISON_GREATER_THAN_OR_EQUAL\n60\t        sub_table.freeze\n61\t      end\n62\t      table.freeze\n63\t    end\n64\t\n65\t    NEXT_MATCHER_JUMP_TABLE = [].tap do |table|\n66\t      \"a\".upto(\"z\") do |c|\n67\t        table[c.ord] = [:id, IDENTIFIER].freeze\n68\t        table[c.upcase.ord] = [:id, IDENTIFIER].freeze\n69\t      end\n70\t      table[\"_\".ord] = [:id, IDENTIFIER].freeze\n71\t\n72\t      \"0\".upto(\"9\") do |c|\n73\t        table[c.ord] = [:number, NUMBER_LITERAL].freeze\n74\t      end\n75\t      table[\"-\".ord] = [:number, NUMBER_LITERAL].freeze\n76\t\n77\t      table[\"'\".ord] = [:string, SINGLE_STRING_LITERAL].freeze\n78\t      table[\"\\\"\".ord] = [:string, DOUBLE_STRING_LITERAL].freeze\n79\t      table.freeze\n80\t    end\n81\t\n82\t    SPECIAL_TABLE = [].tap do |table|\n83\t      table[\"|\".ord] = PIPE\n84\t      table[\".\".ord] = DOT\n85\t      table[\":\".ord] = COLON\n86\t      table[\",\".ord] = COMMA\n87\t      table[\"[\".ord] = OPEN_SQUARE\n88\t      table[\"]\".ord] = CLOSE_SQUARE\n89\t      table[\"(\".ord] = OPEN_ROUND\n90\t      table[\")\".ord] = CLOSE_ROUND\n91\t      table[\"?\".ord] = QUESTION\n92\t      table[\"-\".ord] = DASH\n93\t    end\n94\t\n95\t    NUMBER_TABLE = [].tap do |table|\n96\t      \"0\".upto(\"9\") do |c|\n97\t        table[c.ord] = true\n98\t      end\n99\t      table.freeze\n100\t    end\n101\t\n102\t    # ruboc
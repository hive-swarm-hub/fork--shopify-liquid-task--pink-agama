{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SNREZWsS1EP9U3XzSN6dy7","type":"tool_result","content":"1\t# frozen_string_literal: true\n2\t\n3\trequire \"strscan\"\n4\t\n5\tmodule Liquid\n6\t  # Single-pass forward-only scanner for Liquid parsing.\n7\t  # Wraps StringScanner with higher-level methods for common Liquid constructs.\n8\t  # One Cursor per template parse — threaded through all parsing code.\n9\t  class Cursor\n10\t    # Byte constants\n11\t    SPACE   = 32\n12\t    TAB     = 9\n13\t    NL      = 10\n14\t    CR      = 13\n15\t    FF      = 12\n16\t    DASH    = 45  # '-'\n17\t    DOT     = 46  # '.'\n18\t    COLON   = 58  # ':'\n19\t    PIPE    = 124 # '|'\n20\t    QUOTE_S = 39  # \"'\"\n21\t    QUOTE_D = 34  # '\"'\n22\t    LBRACK  = 91  # '['\n23\t    RBRACK  = 93  # ']'\n24\t    LPAREN  = 40  # '('\n25\t    RPAREN  = 41  # ')'\n26\t    QMARK   = 63  # '?'\n27\t    HASH    = 35  # '#'\n28\t    USCORE  = 95  # '_'\n29\t    COMMA   = 44\n30\t    ZERO    = 48\n31\t    NINE    = 57\n32\t    PCT     = 37  # '%'\n33\t    LCURLY  = 123 # '{'\n34\t    RCURLY  = 125 # '}'\n35\t\n36\t    attr_reader :ss\n37\t\n38\t    def initialize(source)\n39\t      @source = source\n40\t      @ss = StringScanner.new(source)\n41\t    end\n42\t\n43\t    # ── Position ────────────────────────────────────────────────────\n44\t    def pos = @ss.pos\n45\t\n46\t    def pos=(n)\n47\t      @ss.pos = n\n48\t    end\n49\t\n50\t    def eos? = @ss.eos?\n51\t    def peek_byte = @ss.peek_byte\n52\t    def scan_byte = @ss.scan_byte\n53\t\n54\t    # Reset scanner to a new string (for reuse on sub-markup)\n55\t    def reset(source)\n56\t      @source = source\n57\t      @ss.string = source\n58\t    end\n59\t\n60\t    # Extract a slice from the source (deferred allocation)\n61\t    def slice(start, len)\n62\t      @source.byteslice(start, len)\n63\t    end\n64\t\n65\t    # ── Whitespace ──────────────────────────────────────────────────\n66\t    # Skip spaces/tabs/newlines/cr, return count of newlines skipped\n67\t    def skip_ws\n68\t      nl = 0\n69\t      while (b = @ss.peek_byte)\n70\t        case b\n71\t        when SPACE, TAB, CR, FF then @ss.scan_byte\n72\t        when NL then @ss.scan_byte\n73\t                     nl += 1\n74\t        else break\n75\t        end\n76\t      end\n77\t      nl\n78\t    end\n79\t\n80\t    # Check if remaining bytes are all whitespace\n81\t    def rest_blank?\n82\t      saved = @ss.pos\n83\t      @ss.skip(/\\s*/)\n84\t      result = @ss.eos?\n85\t      @ss.pos = saved\n86\t      result\n87\t    end\n88\t\n89\t    # Regex for identifier: [a-zA-Z_][\\w-]*\\??\n90\t    ID_REGEX = /[a-zA-Z_][\\w-]*\\??/\n91\t\n92\t    # ── Identifiers ─────────────────────────────────────────────────\n93\t    # Skip an identifier without allocating a string. Returns length skipped, or 0.\n94\t    def skip_id\n95\t      @ss.skip(ID_REGEX) || 0\n96\t    end\n97\t\n98\t    # Check if next id matches expected string, consume if so. No allocation.\n99\t    def expect_id(expected)\n100\t      start = @ss.pos\n101\t      len = @ss.skip(ID_REGEX)\n102\t      if len == expected.bytesize\n103\t        # Compare bytes directly without allocating a string\n104\t        i = 0\n105\t        while i < len\n106\t          unless @source.getbyte(start + i) == expected.getbyte(i)\n107\t            @ss.pos = start\n108\t            return false\n109\t          end\n110\t          i += 1\n111\t        end\n112\t        return true\n113\t      end\n114\t      @ss.pos = start if len\n115\t      false\n116\t    end\n117\t\n118\t    # Scan a single identifier: [a-zA-Z_][\\w-]*\\??\n119\t    # Returns the string or nil if not at an identifier\n120\t    def scan_id\n121\t      @ss.scan(ID_REGEX)\n122\t    end\n123\t\n124\t    # Scan a tag name: '#' or \\w+\n125\t    def scan_tag_name\n126\t      if @ss.peek_byte == HASH\n127\t        @ss.scan_byte\n128\t        \"#\"\n129\t      else\n130\t        scan_id\n131\t      end\n132\t    end\n133\t\n134\t    # Regex for numbers: -?\\d+(\\.\\d+)?\n135\t    FLOAT_REGEX = /-?\\d+\\.\\d+/\n136\t    INT_REGEX = /-?\\d+/\n137\t\n138\t    # ── Numbers ─────────────────────────────────────────────────────\n139\t    # Try to scan an integer or float. Returns the number or nil.\n140\t    def scan_number\n141\t      if (s = @ss.scan(FLOAT_REGEX))\n142\t        s.to_f\n143\t      elsif (s = @ss.scan(INT_REGEX))\n144\t        s.to_i\n145\t      end\n146\t    end\n147\t\n148\t    # Regex for quoted string content (without quotes)\n149\t    SINGLE_QUOTED_CONTENT = /'([^']*)'/\n150\t    DOUBLE_QUOTED_CONTENT = /\"([^\"]*)\"/\n151\t\n152\t    # ── Strings ─────────────────────────────────────────────────────\n153\t    # Scan a quoted string ('...' or \"...\"). Returns the content without quotes, or nil.\n154\t    def scan_quoted_string\n155\t      if @ss.scan(SINGLE_QUOTED_CONTENT) || @ss.scan(DOUBLE_QUOTED_CONTENT)\n156\t        @ss[1]\n157\t      end\n158\t    end\n159\t\n160\t    # Regex for quoted strings (single or double quoted, including quotes)\n161\t    QUOTED_STRING_RAW = /\"[^\"]*\"|'[^']*'/\n162\t\n163\t    # Scan a quoted string including quotes. Returns the full \"...\" or '...' string, or nil.\n164\t    def scan_quoted_string_raw\n165\t      @ss.scan(QUOTED_STRING_RAW)\n166\t    end\n167\t\n168\t    # Regex for dotted identifier: name(.name)*\n169\t    DOTTED_ID_REGEX = /[a-zA-Z_][\\w-]*\\??(?:\\.[a-zA-Z_][\\w-]*\\??)*/\n170\t\n171\t    # ── Expressions ─────────────────────────────────────────────────\n172\t    # Scan a simple variable lookup: name(.name)* — no brackets, no filters\n173\t    # Returns the string or nil\n174\t    def scan_dotted_id\n175\t      @ss.scan(DOTTED_ID_REGEX)\n176\t    end\n177\t\n178\t    # Skip a fragment without allocating. Returns length skipped, or 0.\n179\t    def skip_fragment\n180\t      @ss.skip(QUOTED_STRING_RAW) || @ss.skip(UNQUOTED_FRAGMENT) || 0\n181\t    end\n182\t\n183\t    # Regex for unquoted fragment: non-white